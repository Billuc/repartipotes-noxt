{
  "name": "noxt-template",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "dev": "MODE=development bun run --watch ./index.ts",
    "build": "bun build --target=bun --outdir=dist index.ts",
    "preview": "cd dist && bun run ./index.js",
    "prerender-static": "bun run ./prerender.ts",
    "prerender-static-preview": "bun run ./prerender.ts --preview"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "noxt": "github:Billuc/noxt"
  }
}
